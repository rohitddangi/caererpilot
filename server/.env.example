# =================================================================
# CareerPilot AI — .env.example
# Copy to .env and fill in your values.
# =================================================================

PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:5000

# MongoDB Atlas
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/careerpilot?retryWrites=true&w=majority

# JWT (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth (from console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# SMTP Email (leave blank in dev to use Ethereal auto-accounts)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM_NAME=CareerPilot AI

# Admin
ADMIN_EMAIL=

# Gemini AI
GEMINI_API_KEY=

# Firebase Admin
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT=
